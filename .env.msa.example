# ==============================================================================
# MSA Program — Local Development Environment
# Copy to .env and fill in real values to run the MSA instance locally.
# ==============================================================================

DEPLOYMENT_ENV=local

GCP_PROJECT_ID=meded-gcp-sandbox
GCP_REGION=us-central1
GCP_CREDENTIALS_PATH=./path-to-your-service-account-key.json

MODEL_NAME=gemini-2.5-flash
TEMPERATURE=0.7
MAX_OUTPUT_TOKENS=2048

MAX_TURNS=10
MIN_COMPETENCY_COVERAGE=3

LOG_TO_FILE=true
LOG_LEVEL=INFO
LOG_DIRECTORY=./logs

FIRESTORE_DATABASE=(default)

OAUTH_CLIENT_ID=your-client-id-here.apps.googleusercontent.com
OAUTH_CLIENT_SECRET=your-client-secret-here
OAUTH_REDIRECT_URI=http://localhost:8080/auth/callback
OAUTH_DOMAIN_RESTRICTION=false

JWT_SECRET_KEY=development-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=168

DEBUG=true

# ==============================================================================
# MSA-specific program configuration
# ==============================================================================

PROGRAM_ID=msa
PROGRAM_NAME=MS in Anesthesia Program
PROGRAM_COLOR=#1565a0
RATING_TYPE=numeric
SYSTEM_PROMPT_PATH=./prompts/system_prompt_msa.md
SURVEY_TEMPLATE=survey.html
